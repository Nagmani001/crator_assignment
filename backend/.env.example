# Copy to backend/.env and fill in real values. backend/.env is gitignored.
# Project-root .env (../.env) is also loaded and takes priority for shared vars.

# Notion internal integration secret. Required by register_notion_mcp + executor.
NOTION_TOKEN=ntn_replace_me

# Django secret. Change for any non-throwaway use.
DJANGO_SECRET_KEY=dev-django-secret-change-me

# JWT signing secret. Change for any non-throwaway use.
JWT_SECRET=dev-jwt-secret-change-me

# JWT TTL in minutes. Default 20.
JWT_TTL_MINUTES=20

# Django debug flag. "1" or "0".
DJANGO_DEBUG=1
