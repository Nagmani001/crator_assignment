# Anthropic API key for claude-agent-sdk.
ANTHROPIC_API_KEY=sk-ant-replace-me

# Agent UUID printed by `python manage.py register_notion_mcp` in backend.
AGENT_ID=replace-with-agent-uuid

# Notion page the demo reads/updates.
NOTION_PAGE_ID=replace-with-notion-page-id

# Notion block on that page the demo attempts to delete (expected 403).
NOTION_BLOCK_ID=replace-with-notion-block-id

# Gateway base URL. Default matches backend runserver.
GATEWAY_URL=http://localhost:8000
